<file path="adobe-slides/src/styles.css">
/* Reset-ish */
* { box-sizing: border-box; }
html, body, #root { height: 100%; }
body {
  margin: 0;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  font-family: Menlo, Monaco, 'Courier New', monospace; /* Cursor vibe */
  color: var(--fg);
  background: var(--bg);
}

/* Theme tokens: graphite + silver */
:root {
  --bg: #0b0b0e;
  --fg: #e6e8ec;
  --muted: #a5aab5;
  --panel: rgba(255,255,255,0.035);
  --panel-strong: rgba(255,255,255,0.06);
  --border: rgba(255,255,255,0.12);
  --shadow: 0 22px 70px rgba(0,0,0,0.45);
  --radius: 18px;

  /* Accent is a single color, set per slide (no component gradients) */
  --accent: #bfc7d4; /* default; overridden per slide via inline style */
}

/* Background: subtle grid + optional soft burst */
.bgGrid {
  position: fixed; inset: 0; pointer-events: none; z-index: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 24px 24px, 24px 24px;
  background-position: -12px -12px, -12px -12px;
  opacity: .6;
}
.bgBurst {
  position: fixed; inset: -15%;
  /* single-color "burst" (uses --accent); no component gradients */
  background:
    radial-gradient(40% 40% at 70% 22%, color-mix(in oklab, var(--accent) 60%, transparent), transparent 60%),
    radial-gradient(45% 45% at 20% 80%, color-mix(in oklab, var(--accent) 45%, transparent), transparent 65%);
  filter: blur(70px) saturate(1.1);
  animation: float 14s ease-in-out infinite;
  z-index: 0;
}
@keyframes float { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-2%) } }

/* Stage & frame */
.stage { position: relative; z-index: 1; height: 100%; display: grid; place-items: center; padding: 28px; }
.frame {
  width: min(1200px, 92vw);
  aspect-ratio: 16 / 9;
  background: var(--panel-strong);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  backdrop-filter: blur(10px);
  box-shadow: var(--shadow);
  position: relative;
  display: grid; grid-template-rows: 1fr auto;
  overflow: hidden;
}

/* Cursor logo chip */
.logo {
  position: fixed; top: 18px; left: 22px; z-index: 2;
  display: inline-flex; align-items: center; gap: 8px;
  padding: 8px 12px; border-radius: 999px;
  background: rgba(255,255,255,0.04); border: 1px solid var(--border);
  transition: transform .2s ease, background .2s ease;
}
.logo:hover { transform: translateY(-1px); background: rgba(255,255,255,0.06); }
.logo img { height: 18px; display: block; }

/* Progress (silver bar that fills with accent color) */
.progress {
  position: fixed; top: 0; left: 0; right: 0; height: 3px; overflow: hidden; z-index: 3;
  background: rgba(255,255,255,0.1);
}
.progress .bar {
  height: 100%; transform-origin: 0 50%;
  background: var(--accent);
  box-shadow: 0 0 18px color-mix(in oklab, var(--accent) 60%, transparent);
}

/* Cards / slides */
.card {
  margin: 0; padding: 48px 56px;
  display: grid; align-content: center; justify-items: start;
  gap: 18px;
  background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); /* subtle sheen */
}
.card.title { justify-items: center; text-align: center; }
.eyebrow { letter-spacing: .24em; text-transform: uppercase; color: var(--muted); font-size: 14px; font-weight: 600; }
.titleText { font-size: clamp(36px, 6vw, 64px); line-height: 1.05; font-weight: 800; }
.subtitle { font-size: clamp(16px, 2vw, 22px); color: var(--muted); }

.heading { font-size: clamp(26px, 3.6vw, 38px); font-weight: 800; }
.card.bullets ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 14px; }
.card.bullets li { font-size: clamp(18px, 2.2vw, 22px); line-height: 1.45; }
.dot {
  display: inline-block; width: 9px; height: 9px; margin-right: 10px; border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 14px color-mix(in oklab, var(--accent) 65%, transparent);
}

.card.quote blockquote { font-size: clamp(24px, 3.2vw, 36px); line-height: 1.25; font-weight: 800; font-style: italic; }
.card.quote .by { color: var(--muted); }

.card.table .tableWrap { width: 100%; overflow: auto; }
.card.table table {
  width: 100%; border-collapse: collapse; font-size: clamp(14px, 1.7vw, 18px);
  background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 12px; overflow: hidden;
}
.card.table th, .card.table td { padding: 14px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); }
.card.table thead th { text-align: left; color: var(--muted); }

/* Footer controls */
.footer { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-top: 1px solid var(--border); background: rgba(255,255,255,0.02); }
.index { color: var(--muted); font-variant-numeric: tabular-nums; }
.controls { display: flex; gap: 8px; }
.controls button {
  appearance: none; border: 1px solid var(--border); background: var(--panel);
  color: var(--fg); padding: 8px 12px; border-radius: 10px; cursor: pointer;
  font-family: Menlo, Monaco, 'Courier New', monospace;
  transition: transform .12s ease, background .2s ease;
}
.controls button:hover { transform: translateY(-1px); background: var(--panel-strong); }

/* Overlays */
.overlay { position: fixed; inset: 0; background: rgba(3,6,10,0.5); backdrop-filter: blur(4px); display: grid; place-items: center; z-index: 5; }
.overlayPanel {
  width: min(980px, 90vw); max-height: 80vh; overflow: auto;
  border: 1px solid var(--border); border-radius: 14px; background: rgba(15,18,24,0.92);
  box-shadow: var(--shadow);
}
.overlayHeader { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; border-bottom: 1px solid var(--border); }
.overlayHeader button { appearance: none; background: transparent; color: var(--fg); border: 0; font-size: 18px; cursor: pointer; }
.notes { margin: 0; padding: 16px; white-space: pre-wrap; color: #d8e1ff; }

.grid { display: grid; gap: 14px; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); padding: 18px; width: min(1200px, 94vw); }
.thumb { border: 1px solid var(--border); background: rgba(255,255,255,0.03); border-radius: 12px; cursor: pointer; transition: transform .12s ease, background .2s ease; }
.thumb:hover { transform: translateY(-1px); background: rgba(255,255,255,0.05); }
.thumb.active { outline: 2px solid var(--accent); }
.thumbInner { padding: 14px; text-align: left; }
.thumbTitle { margin-top: 8px; font-weight: 700; }

@media (max-width: 860px) {
  .frame { aspect-ratio: auto; height: 88vh; }
  .card { padding: 32px; }
}
