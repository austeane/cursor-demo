    ],
  },
  {
    type: 'table',
    bg: 'plain',
    title: 'At‑a‑glance (pilot‑task fit)',
    headers: ['Dimension', 'Cursor', 'Copilot', 'Windsurf'],
    rows: [
      ['Repo awareness', 'Index + PR search', 'Repo indexing', 'Context + Cascade'],
      ['PR review', 'Bugbot, fix links', 'PR insights/summaries', 'Cascade review'],
