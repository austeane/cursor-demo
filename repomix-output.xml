.controls button:hover { transform: translateY(-1px); background: var(--panel-strong); }

/* Overlays */
.overlay { position: fixed; inset: 0; background: rgba(3,6,10,0.5); backdrop-filter: blur(4px); display: grid; place-items: center; z-index: 5; }
.overlayPanel {
  width: min(980px, 90vw); max-height: 80vh; overflow: auto;
  border: 1px solid var(--border); border-radius: 14px; background: rgba(15,18,24,0.92);
  box-shadow: var(--shadow);
}
.overlayHeader { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; border-bottom: 1px solid var(--border); }
.overlayHeader button { appearance: none; background: transparent; color: var(--fg); border: 0; font-size: 18px; cursor: pointer; }
.notes { margin: 0; padding: 16px; white-space: pre-wrap; color: #d8e1ff; }

.grid { display: grid; gap: 14px; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); padding: 18px; width: min(1200px, 94vw); }
.thumb { border: 1px solid var(--border); background: rgba(255,255,255,0.03); border-radius: 12px; cursor: pointer; transition: transform .12s ease, background .2s ease; }
.thumb:hover { transform: translateY(-1px); background: rgba(255,255,255,0.05); }
.thumb.active { outline: 2px solid var(--accent); }
.thumbInner { padding: 14px; text-align: left; }
.thumbTitle { margin-top: 8px; font-weight: 700; }

@media (max-width: 860px) {
  .frame { aspect-ratio: auto; height: 88vh; }
  .card { padding: 32px; }
}
