  cursor: pointer; transition: transform .12s ease, background .2s ease;
}
.thumb:hover { transform: translateY(-1px); background: rgba(255,255,255,0.05); }
.thumb.active { outline: 2px solid var(--accent-b); }
.thumbInner { padding: 14px; text-align: left; }
